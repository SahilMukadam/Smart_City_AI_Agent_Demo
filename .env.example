# ══════════════════════════════════════════════════════════════════
# Smart City AI Agent — Environment Configuration
# ══════════════════════════════════════════════════════════════════
# Copy to .env:  copy .env.example .env  (Windows)
#                cp .env.example .env     (Mac/Linux)
# Then fill in your API keys below.
# ══════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────
APP_NAME=Smart City AI Agent
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# ── Default Location ──────────────────────────────────────────────
# Change these to adapt the agent for any city.
DEFAULT_LATITUDE=51.5074
DEFAULT_LONGITUDE=-0.1278
DEFAULT_LOCATION_NAME=Central London

# ── Bounding Box (constrains geocoding + incident search) ─────────
BBOX_MIN_LAT=51.28
BBOX_MIN_LON=-0.51
BBOX_MAX_LAT=51.69
BBOX_MAX_LON=0.33

# ── Google Gemini (REQUIRED) ──────────────────────────────────────
# Get free key: https://aistudio.google.com/app/apikey
# Model: gemini-2.5-flash (250 req/day on free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── TomTom (REQUIRED for traffic flow + map tiles) ───────────────
# Sign up: https://developer.tomtom.com (free tier: 2,500 req/day)
TOMTOM_API_KEY=

# ── OpenAQ (REQUIRED for air quality) ────────────────────────────
# Sign up: https://explore.openaq.org (free)
OPENAQ_API_KEY=

# ── TfL (OPTIONAL — works without key, key gives higher limits) ──
# Register: https://api-portal.tfl.gov.uk
TFL_APP_KEY=

# ── Cache & HTTP ──────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=2
